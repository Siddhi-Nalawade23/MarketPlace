<div style="background-color:#F5F6F8; padding:40px 20px; font-family:'Helvetica Neue', Arial, sans-serif;">
  <div style="max-width:480px; margin:0 auto; background:#FFFFFF; border:1px solid #DDE1E8; border-radius:8px; overflow:hidden;">

    <!-- Header -->
    <div style="background-color:#1B1F3B; padding:24px 32px;">
      <span style="color:#FFFFFF; font-size:20px; font-weight:600; letter-spacing:-0.02em;">
        Marketplace
      </span>
    </div>

    <!-- Body -->
    <div style="padding:32px;">
      <p style="margin:0 0 16px; font-size:15px; color:#1B1F3B;">
        Hi <%= @invoice.seller.name %>,
      </p>

      <p style="margin:0 0 24px; font-size:14px; color:#4A4E63; line-height:1.6;">
        A new order has come through. Please find the invoice for
        Order&nbsp;#<%= @invoice.order_id %> attached to this email as a PDF.
      </p>

      <!-- Invoice summary card -->
      <div style="border:1px dashed #DDE1E8; border-radius:6px; padding:20px 24px; margin-bottom:24px;">
        <table style="width:100%; border-collapse:collapse; font-size:14px;">
          <tr>
            <td style="padding:6px 0; color:#6B7085;">Invoice Number</td>
            <td style="padding:6px 0; text-align:right; font-family:'Courier New', monospace; color:#1B1F3B;">
              <%= @invoice.invoice_number %>
            </td>
          </tr>
          <tr>
            <td style="padding:6px 0; color:#6B7085;">Order</td>
            <td style="padding:6px 0; text-align:right; font-family:'Courier New', monospace; color:#1B1F3B;">
              #<%= @invoice.order_id %>
            </td>
          </tr>
          <tr>
            <td style="padding:6px 0; color:#6B7085;">Date</td>
            <td style="padding:6px 0; text-align:right; font-family:'Courier New', monospace; color:#1B1F3B;">
              <%= @invoice.created_at.strftime('%d %b %Y') %>
            </td>
          </tr>
          <tr>
            <td colspan="2" style="border-top:1px dashed #DDE1E8; padding-top:12px;"></td>
          </tr>
          <tr>
            <td style="padding-top:12px; font-size:15px; font-weight:600; color:#1B1F3B;">Amount</td>
            <td style="padding-top:12px; text-align:right; font-family:'Courier New', monospace; font-size:18px; font-weight:600; color:#1B1F3B;">
              ₹<%= @invoice.amount %>
            </td>
          </tr>
        </table>
      </div>

      <p style="margin:0; font-size:14px; color:#4A4E63; line-height:1.6;">
        Thank you for selling with Marketplace.
      </p>
    </div>

    <!-- Footer -->
    <div style="background-color:#F5F6F8; padding:16px 32px; border-top:1px solid #DDE1E8;">
      <p style="margin:0; font-size:12px; color:#9096A8;">
        This is an automated invoice notification from Marketplace.
      </p>
    </div>

  </div>
</div>